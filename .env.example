# ---- PeopleDesk environment (copy to .env and fill in) ----

# Postgres (used by docker-compose and the API)
POSTGRES_USER=peopledesk
POSTGRES_PASSWORD=change-me-in-real-life
POSTGRES_DB=peopledesk
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Full SQLAlchemy URL. Inside docker-compose leave host as `postgres`.
# For running the API on the host against the compose DB, use localhost:5432.
DATABASE_URL=postgresql+psycopg://peopledesk:change-me-in-real-life@postgres:5432/peopledesk

# ---- Auth ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=replace-with-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Groq (generation ONLY — never commit a real key) ----
# Get one at https://console.groq.com/keys
GROQ_API_KEY=gsk_replace_me
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_SMALL=llama-3.1-8b-instant

# ---- Embeddings (local, via fastembed — NOT Groq) ----
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# ---- App / CORS ----
APP_ENV=development
WEB_ORIGIN=http://localhost:5173

# ---- Seed admin (created by seed.py) ----
SEED_ADMIN_EMAIL=admin@peopledesk.io
SEED_ADMIN_PASSWORD=Admin123!
